# Example nginx config for production GIOP portal (no Docker).
# Build: cd "backoffice-ui/cloudhound frontend portal" && npm run build
# Copy dist/ to /var/www/giop-portal and adjust paths below.

server {
    listen 80;
    server_name giop.local;

    root /var/www/giop-portal;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/v1/ {
        proxy_pass http://127.0.0.1:5000/api/v1/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /ocr-api/ {
        proxy_pass http://127.0.0.1:5002/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }
}

# Martin tiles: set VITE_MARTIN_URL at build time to a public URL, or add:
# location /martin/ {
#     proxy_pass http://127.0.0.1:3001/;
# }
